aws_region    = "us-east-1"
create_vpc    = true
vpc_cidr      = "10.0.0.0/16"
public_subnet_cidr = "10.0.1.0/24"
instance_type      = "t3.small"
ami_id             = "ami-xxxxxxxxxxxxxxxxx"
swap_size_mb       = 1024
vm_swappiness      = 10
docker_log_max_size = "10m"
docker_log_max_file = 3

dashboard_hostname = "dashboard.craftalism.local"
api_hostname       = "api.craftalism.local"
auth_hostname      = "auth.craftalism.local"

dashboard_basic_auth_username      = "craftalism"
dashboard_basic_auth_password_hash = "$2a$14$replace.with.a.real.bcrypt.hash"

ssh_allowed_cidrs = [
  "203.0.113.10/32",
]

create_route53_records = false
# route53_zone_id = "Z0123456789ABCDEF"

budget_alert_email       = "henrique@example.com"
monthly_budget_limit_usd = 5

tags = {
  Owner = "henrique"
}
